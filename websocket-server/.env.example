# rename this to .env

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_URL=wss://api.openai.com/v1/realtime?model=gpt-4o-realtime-preview-2024-12-17

# Server settings
NODE_ENV=development
PORT=8081  # Can be overridden via command line arguments
ALLOWED_ORIGIN=http://localhost:3000

# Backend ngrok url (will be auto-configured when using npm run start:ngrok)
PUBLIC_URL=your-ngrok-url.ngrok-free.app

# Twilio credentials for outbound calling
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number