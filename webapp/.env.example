# rename this to .env

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
BACKEND_URL=your-backend-url
TWILIO_PHONE_NUMBER=your-twilio-phone-number
PUBLIC_URL=your-public-url

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe Configuration
# Get these from your Stripe Dashboard at https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key  # Use pk_test_... for test mode, pk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_secret_key  # Use sk_test_... for test mode, sk_live_... for production
# Get this from the Stripe CLI or Stripe Dashboard > Developers > Webhooks
# Run: stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000